# Environment variables for HealthyFoods

# Application
SECRET_KEY=generate-a-secure-random-key-here
DEBUG=False

# API Authentication (comma-separated list of valid API keys)
# API_KEYS=key1,key2,key3

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://healthyfoods-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=0c2880a40d484684991e958a40632c53
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# Azure Content Safety
AZURE_CONTENT_SAFETY_ENDPOINT=https://eastus.api.cognitive.microsoft.com/
AZURE_CONTENT_SAFETY_KEY=ee849a5be8784977af6b0c37ddb8a1a8

# Azure Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://...

# Azure Key Vault
AZURE_KEY_VAULT_URL=https://healthyfoods-kv.vault.azure.net/

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=healthyfoodsstorage

# Azure Service Bus
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-servicebus.servicebus.windows.net/;...

# Azure MCP
AZURE_MCP_ENDPOINT=https://your-mcp-endpoint.azure.com/

# Payment Gateway
PAYMENT_GATEWAY_API_KEY=your-payment-gateway-key

# Database
DATABASE_URL=sqlite:///./healthyfoods.db
# Or for PostgreSQL: postgresql://user:password@localhost:5432/healthyfoods

# Redis
REDIS_URL=redis://localhost:6379

# Docker Compose
POSTGRES_PASSWORD=secure-password-here
